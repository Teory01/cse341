{
  "swagger": "2.0",
  "info": {
    "title": "Books & Authors API",
    "description": "API for managing books and authors. POST, PUT and DELETE routes require authentication via Google OAuth.",
    "version": "1.0.0"
  },
  "host": "cse341-qvea.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "securityDefinitions": {
  "OAuth2": {
    "type": "oauth2",
    "flow": "accessCode",
    "authorizationUrl": "https://accounts.google.com/o/oauth2/auth",
    "tokenUrl": "https://oauth2.googleapis.com/token",
    "scopes": {
      "profile": "Access your Google profile",
      "email": "Access your Google email"
    }
  }
},
  "paths": {
    "/auth/login": {
      "get": {
        "summary": "Login with Google",
        "description": "Redirects to Google OAuth login page",
        "responses": {
          "302": { "description": "Redirects to Google login" }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "summary": "Logout",
        "description": "Logs the user out",
        "responses": {
          "302": { "description": "Redirects after logout" }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "summary": "Get logged in user profile",
        "description": "Returns the profile of the currently logged in user",
        "responses": {
          "200": { "description": "User profile returned successfully" },
          "401": { "description": "Not logged in" }
        }
      }
    },

    "/books": {
      "get": {
        "summary": "Get all books",
        "description": "Returns a list of all books",
        "produces": ["application/json"],
        "responses": {
          "200": { "description": "Successful operation" }
        }
      },
      "post": {
        "summary": "Create a new book",
        "description": "Adds a new book. Requires authentication.",
        "security": [{ "OAuth2": ["profile", "email"] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Book"
            }
          }
        ],
        "responses": {
          "201": { "description": "Book created successfully" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized - must be logged in" }
        }
      }
    },

    "/books/{id}": {
      "get": {
        "summary": "Get a book by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Book found" },
          "404": { "description": "Book not found" }
        }
      },
      "put": {
        "summary": "Update a book",
        "description": "Updates a book. Requires authentication.",
        "security": [{ "OAuth2": ["profile", "email"] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Book"
            }
          }
        ],
        "responses": {
          "200": { "description": "Book updated successfully" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Book not found" }
        }
      },
      "delete": {
        "summary": "Delete a book",
        "description": "Deletes a book. Requires authentication.",
        "security": [{ "OAuth2": ["profile", "email"] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Book deleted successfully" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Book not found" }
        }
      }
    },

    "/authors": {
      "get": {
        "summary": "Get all authors",
        "description": "Returns a list of all authors",
        "produces": ["application/json"],
        "responses": {
          "200": { "description": "Successful operation" }
        }
      },
      "post": {
        "summary": "Create a new author",
        "description": "Adds a new author. Requires authentication.",
        "security": [{ "OAuth2": ["profile", "email"] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Author"
            }
          }
        ],
        "responses": {
          "201": { "description": "Author created successfully" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },

    "/authors/{id}": {
      "get": {
        "summary": "Get an author by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Author found" },
          "404": { "description": "Author not found" }
        }
      },
      "put": {
        "summary": "Update an author",
        "description": "Updates an author. Requires authentication.",
        "security": [{ "OAuth2": ["profile", "email"] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Author"
            }
          }
        ],
        "responses": {
          "200": { "description": "Author updated successfully" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Author not found" }
        }
      },
      "delete": {
        "summary": "Delete an author",
        "description": "Deletes an author. Requires authentication.",
        "security": [{ "OAuth2": ["profile", "email"] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Author deleted successfully" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Author not found" }
        }
      }
    }
  },

  "definitions": {
    "Book": {
      "type": "object",
      "required": ["title", "authorName", "genre", "publishedYear", "pages", "language", "summary"],
      "properties": {
        "title": { "type": "string" },
        "authorName": { "type": "string" },
        "genre": { "type": "string" },
        "publishedYear": { "type": "integer" },
        "pages": { "type": "integer" },
        "language": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "Author": {
      "type": "object",
      "required": ["firstName", "lastName", "nationality", "birthYear", "genre", "awardsWon", "biography"],
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "nationality": { "type": "string" },
        "birthYear": { "type": "integer" },
        "genre": { "type": "string" },
        "awardsWon": { "type": "integer" },
        "biography": { "type": "string" }
      }
    }
  }
}